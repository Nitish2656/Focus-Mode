{
  "expo": {
    "name": "Focus Tracker",
    "slug": "focusmode-professional",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./app_assets/icon.png",
    "userInterfaceStyle": "dark",
    "splash": {
      "image": "./app_assets/splash-icon.png",
      "resizeMode": "contain",
      "backgroundColor": "#0a0a0f"
    },
    "ios": {
      "supportsTablet": true,
      "bundleIdentifier": "com.focus.tracker.mobile",
      "infoPlist": {
        "ITSAppUsesNonExemptEncryption": false
      }
    },
    "android": {
      "package": "com.focus.tracker.mobile",
      "permissions": [
        "android.permission.PACKAGE_USAGE_STATS",
        "android.permission.SYSTEM_ALERT_WINDOW"
      ],
      "adaptiveIcon": {
        "backgroundColor": "#0a0a0f",
        "foregroundImage": "./app_assets/android-icon-foreground.png",
        "backgroundImage": "./app_assets/android-icon-background.png",
        "monochromeImage": "./app_assets/android-icon-monochrome.png"
      }
    },
    "web": {
      "favicon": "./app_assets/favicon.png"
    },
    "extra": {
      "eas": {
        "projectId": "a6c6783d-ab7d-44ec-9fb1-b89a6938cfbc"
      }
    },
    "plugins": [
      "expo-font",
      "expo-asset"
    ]
  }
}
